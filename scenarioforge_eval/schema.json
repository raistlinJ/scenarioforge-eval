{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScenarioForge-Eval Spec",
  "description": "Specification for batch generating scenarios",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Base name of the scenario"
    },
    "iterations": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of times to run this specification with randomized generation"
    },
    "topology": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["star", "segmented"]
        },
        "routers": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "hosts": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "randomize": { "type": "boolean" }
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "randomize": { "type": "boolean" }
      }
    },
    "vulns": {
      "type": "object",
      "properties": {
        "randomize": { "type": "boolean" },
        "count": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        }
      }
    },
    "flows": {
      "type": "object",
      "properties": {
        "randomize": { "type": "boolean" },
        "chain_length": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "allow_duplicates": { "type": "boolean" }
      }
    }
  }
}
