{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScenarioForge-Eval Spec",
  "description": "Specification for batch generating scenarios",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Base name of the scenario"
    },
    "iterations": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of times to run this specification with randomized generation"
    },
    "topology": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["star", "tree", "mesh", "segmented"]
        },
        "routers": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "hosts": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "randomize": { "type": "boolean" }
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "randomize": { "type": "boolean" },
        "count": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "density": { "type": "number", "minimum": 0, "maximum": 1 },
        "include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "vulns": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "randomize": { "type": "boolean" },
        "count": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "flows": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "randomize": { "type": "boolean" },
        "count": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ],
          "description": "Legacy alias for chain_length."
        },
        "chain_length": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "allow_duplicates": { "type": "boolean" }
      }
    },
    "segmentation": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "randomize": { "type": "boolean" },
        "density": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "hitl": {
      "type": "object",
      "properties": {
        "use_env": { "type": "boolean", "description": "If true, extracts hitl config from .scenarioforge.env" }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "policy": {
          "type": "string",
          "enum": ["strict", "warning_tolerant", "warning-tolerant"],
          "description": "Validation pass policy for execute. strict requires validation_summary.ok=true; warning_tolerant allows warning-only validation summaries."
        }
      }
    }
  }
}
